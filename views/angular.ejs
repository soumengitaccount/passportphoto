<script>

var app = angular.module("passportApp",[]);

app.controller("photoCtrl", function($scope){
$scope.imageUrl = "http://127.0.0.1:3000/uploads/passport_photo_1772858185736.jpg";
$scope.process = async function(){
alert('clicked');
return;
// const file = document.getElementById("fileInput").files[0];

// if(!file){
// alert("Upload image first");
// return;
// }
// fetch image from URL
const response = await fetch($scope.imageUrl);
const file = await response.blob();

const blob = await removeBackground(file);

const img = new Image();

img.onload = function(){

const canvas = document.createElement("canvas");
const ctx = canvas.getContext("2d");

canvas.width = img.width;
canvas.height = img.height;

// ctx.fillStyle = "white";
ctx.fillStyle = "#87CEFA"
ctx.fillRect(0,0,canvas.width,canvas.height);

ctx.drawImage(img,0,0);

const finalImage = canvas.toDataURL("image/png");

document.getElementById("preview").src = finalImage;
document.getElementById("download").href = finalImage;

};

img.src = URL.createObjectURL(blob);

};

});

</script>

