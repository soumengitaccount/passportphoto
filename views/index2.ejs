<script>
// Get references to the elements
const customButton = document.getElementById('customButton');
const fileInput = document.getElementById('fileInput');
// const fileNameDisplay = document.getElementById('fileNameDisplay');

// 1. Trigger the hidden file input when the custom button is clicked
customButton.addEventListener('click', () => {
    fileInput.click();
});

// 2. Get the file data when a file is selected (the input's value changes)
fileInput.addEventListener('change', () => {
    // Access the selected file(s) via the 'files' property
    const selectedFile = fileInput.files[0]; // Get the first selected file

    if (selectedFile) {
        // Display the file name to the user
        // fileNameDisplay.textContent = `Selected File: ${selectedFile.name}`;

        // The 'selectedFile' is a File object containing data like name, size, and type.
        console.log('File Name:', selectedFile.name);
        console.log('File Size:', selectedFile.size, 'bytes');
        console.log('File Type:', selectedFile.type);
        
        // You can now process the file data further (e.g., using FormData to send to a server).
    } else {
        // fileNameDisplay.textContent = 'No file chosen';
    }
});

    var formdata = new FormData();

$('#fileInput').change(function(event){
    // alert(this.value);
    $("#img_div").addClass('d-none');
    $('#loader').removeClass('d-none');
    var files = event.target.files;
    formdata.set('image',files[0]);
    $.ajax({
        url:'/upload',
        type:"POST",
        processData: false, // Prevents jQuery from processing the data
        contentType: false,
        data:formdata,
        success:function(data){
            // alert(data);
            $( "#original" ).prop( "checked", true );
            $('#loader').addClass('d-none');
            $("#img_div").removeClass('d-none');
            let image  ='<img id="passwortportimage" class="img-thumbnail" height="50px" width="150px"  src="https://passportphoto-ohql.onrender.com/uploads/'+data+'" alt="Image not found try again">';
            // let image  ='<img id="passwortportimage" class="img-thumbnail" height="50px" width="150px"  src="http://127.0.0.1:3000/uploads/'+data+'" alt="Image not found try again">';
            $('#passportimage').html(image);
            $('#image_name').val(data);
        },
        error:function(jqXHR, textStatus, errorThrown){
            console.log('Error:', textStatus, errorThrown);


        }
    })
})

$('#generate').click(function(){
    // alert('clicked');
    let checked_value =$('input[name="background"]:checked').val();
    // alert(checked_value);
    if(checked_value=='original'){
      var image=  $('#image_name').val();
    }
    if(checked_value=='white'){
      var image=  $('#white_image').val();
    }
    if(checked_value=='blue'){
      var image=  $('#blue_image').val();
    }
    let no_ofCopy = $('#no_ofCopy').val();
    $.ajax({
        url:'/generate',
        type:"POST",
        data:{'image':image,'no_ofCopy':no_ofCopy},
        success:function(data){
            // alert(data);
            let doc ='<embed src="https://passportphoto-ohql.onrender.com/pdf/'+data+'" type="application/pdf" width="100%" height="600px" title="Embedded PDF Viewer">';
            // let doc ='<embed src="http://127.0.0.1:3000/pdf/'+data+'" type="application/pdf" width="100%" height="600px" title="Embedded PDF Viewer">';
            $('#modal_body').html(doc);
            $('#staticBackdrop').modal('show');
            
        },
        error:function(jqXHR, textStatus, errorThrown){
            console.log('Error:', textStatus, errorThrown);


        }
    })
})


$('input[name="background"]').on('change', function() {
  // let URL = "http://127.0.0.1:3000/uploads/";
  let URL = "https://passportphoto-ohql.onrender.com/uploads/";
  // let LoaderURL = "http://127.0.0.1:3000/public/loader.gif";
  let LoaderURL = "https://passportphoto-ohql.onrender.com/public/loader.gif";
  $('#passwortportimage').attr('src',LoaderURL);

  let original_image = $('#image_name').val();
  if($(this).val()=='original'){
    let original_image_path = URL+$('#image_name').val(); 
    if(original_image!='' ||original_image!=undefined){
      $('#passwortportimage').attr('src',original_image_path);
    }
  }
  if($(this).val()=='white'){
    let white_image =$('#white_image').val();
    let original_image_path = URL+white_image; 

    if(white_image==''|| white_image==undefined){
      $.ajax({
            url:'change-background',
            type:"POST",
            async:false,
            data:{'color':'white','image':original_image},
            success:function(data){
              console.log(data);
              $('#white_image').val(data);
              $('#passwortportimage').attr('src',URL+data);

            },
            error:function(jqXHR, textStatus, errorThrown){
                console.log('Error:', textStatus, errorThrown);


            }
        });
    }else{
      $('#passwortportimage').attr('src',original_image_path);
    }
  }
  if($(this).val()=='blue'){
    let blue_imge= $('#blue_image').val();
    let original_image_path = URL+blue_imge; 
    
    if(blue_imge=='' || blue_imge==undefined){

      $.ajax({
            url:'/change-background',
            type:"POST",
            async:false,
            data:{'color':'#87CEFA','image':original_image},
            success:function(data){
              console.log(data);
              $('#blue_image').val(data);
              $('#passwortportimage').attr('src',URL+data);

            },
            error:function(jqXHR, textStatus, errorThrown){
                console.log('Error:', textStatus, errorThrown);


            }
        });
    }else{
      $('#passwortportimage').attr('src',original_image_path);

          
    }
  }
  
   
});
</script>


